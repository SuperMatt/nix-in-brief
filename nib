#!/usr/bin/env python3
"""nibble (nib) — brew-like wrapper for nix profile."""

import argparse
import os
import shutil
import subprocess
import sys

NIX_PROFILE_SOURCE = "/nix/var/nix/profiles/default/etc/profile.d/nix-daemon.sh"
DETERMINATE_INSTALLER = "https://install.determinate.systems/nix"
LOCAL_BIN = os.path.expanduser("~/.local/bin")


def run(cmd, check=True):
    return subprocess.run(cmd, check=check)


def nix(*args, check=True):
    return run(["nix"] + list(args), check=check)


def ensure_nix():
    if shutil.which("nix"):
        return
    # Try sourcing the nix profile in case it just needs to be on PATH
    if os.path.isfile(NIX_PROFILE_SOURCE):
        sys.stderr.write(
            "nix found but not on PATH. Re-run after sourcing your shell profile.\n"
        )
    else:
        sys.stderr.write("error: nix not found. Run 'nib setup' first.\n")
    sys.exit(1)


def cmd_setup(args):
    if shutil.which("nix"):
        print("Nix is already installed.")
    else:
        print("Installing Nix via Determinate Systems...")
        run(
            [
                "sh", "-c",
                f'curl --proto \'=https\' --tlsv1.2 -sSf -L {DETERMINATE_INSTALLER} | sh -s -- install --no-confirm',
            ]
        )
        print(f"\nNix installed. You may need to restart your shell or source {NIX_PROFILE_SOURCE}")

    # Copy nib itself to ~/.local/bin
    os.makedirs(LOCAL_BIN, exist_ok=True)
    dest = os.path.join(LOCAL_BIN, "nib")
    src = os.path.realpath(__file__)
    if src != dest:
        shutil.copy2(src, dest)
        os.chmod(dest, 0o755)
        print(f"nib copied to {dest}")
    else:
        print(f"nib is already at {dest}")

    path = os.environ.get("PATH", "")
    if LOCAL_BIN not in path.split(os.pathsep):
        print(f"\nAdd {LOCAL_BIN} to your PATH to use 'nib' from anywhere.")


def cmd_install(args):
    ensure_nix()
    if not args.packages:
        sys.stderr.write("error: specify at least one package\n")
        sys.exit(1)
    pkgs = [f"nixpkgs#{p}" for p in args.packages]
    nix("profile", "install", *pkgs)


def cmd_remove(args):
    ensure_nix()
    if not args.packages:
        sys.stderr.write("error: specify at least one package\n")
        sys.exit(1)
    nix("profile", "remove", *args.packages)


def cmd_upgrade(args):
    ensure_nix()
    nix("profile", "upgrade", ".*")


def _search_nixpkgs(*terms):
    import json
    result = subprocess.run(
        ["nix", "search", "--quiet", "--json", "nixpkgs"] + list(terms),
        capture_output=True, text=True, check=True,
    )
    packages = json.loads(result.stdout)
    if not packages:
        print("No packages found.")
        return
    for key, pkg in sorted(packages.items()):
        # key is e.g. "legacyPackages.x86_64-linux.nerd-fonts.monaspace"
        # strip the first two components to get the install name
        name = key.split(".", 2)[2] if key.count(".") >= 2 else key
        version = pkg.get("version", "")
        description = pkg.get("description", "")
        print(f"{name} ({version})")
        if description:
            print(f"  {description}")
        print()


def cmd_search(args):
    ensure_nix()
    _search_nixpkgs(*args.terms)


def cmd_list(args):
    ensure_nix()
    nix("profile", "list")


def cmd_info(args):
    ensure_nix()
    _search_nixpkgs(f"^{args.package}$")


def cmd_rollback(args):
    ensure_nix()
    nix("profile", "rollback")


def cmd_uninstall_nix(args):
    print("This will completely remove Nix and all installed packages.")
    try:
        answer = input("Are you sure? [y/N] ").strip().lower()
    except (EOFError, KeyboardInterrupt):
        print("\nAborted.")
        sys.exit(0)

    if answer != "y":
        print("Aborted.")
        sys.exit(0)

    installer = shutil.which("nix-installer") or (
        "/nix/nix-installer" if os.path.isfile("/nix/nix-installer") else None
    )
    if not installer:
        sys.stderr.write(
            "error: could not find nix-installer. "
            "See https://install.determinate.systems/nix\n"
        )
        sys.exit(1)

    run([installer, "uninstall", "--no-confirm"])

    nib_bin = os.path.join(LOCAL_BIN, "nib")
    if os.path.isfile(nib_bin):
        os.remove(nib_bin)
        print(f"Removed {nib_bin}")

    print("Nix uninstalled.")


def build_parser():
    parser = argparse.ArgumentParser(
        prog="nib",
        description="nibble (nib) — brew-like wrapper for nix profile",
    )
    sub = parser.add_subparsers(dest="command", metavar="<command>")

    sub.add_parser("setup", help="Install Nix (Determinate Systems) and copy nib to ~/.local/bin")

    p_install = sub.add_parser("install", help="Install packages from nixpkgs")
    p_install.add_argument("packages", nargs="+", metavar="pkg")

    p_remove = sub.add_parser("remove", aliases=["uninstall"], help="Remove installed packages")
    p_remove.add_argument("packages", nargs="+", metavar="pkg")

    sub.add_parser("upgrade", help="Upgrade all installed packages")
    sub.add_parser("update", help="Alias for upgrade")

    p_search = sub.add_parser("search", help="Search nixpkgs")
    p_search.add_argument("terms", nargs="+", metavar="term")

    sub.add_parser("list", help="List installed packages")

    p_info = sub.add_parser("info", help="Show package details")
    p_info.add_argument("package", metavar="pkg")

    sub.add_parser("rollback", help="Undo the last install/remove/upgrade")
    sub.add_parser("uninstall-nix", help="Fully remove Nix and all packages")

    return parser


def main():
    parser = build_parser()
    args = parser.parse_args()

    dispatch = {
        "setup": cmd_setup,
        "install": cmd_install,
        "remove": cmd_remove,
        "uninstall": cmd_remove,
        "upgrade": cmd_upgrade,
        "update": cmd_upgrade,
        "search": cmd_search,
        "list": cmd_list,
        "info": cmd_info,
        "rollback": cmd_rollback,
        "uninstall-nix": cmd_uninstall_nix,
    }

    if args.command is None:
        parser.print_help()
        sys.exit(0)

    handler = dispatch.get(args.command)
    if handler is None:
        parser.print_help()
        sys.exit(1)

    try:
        handler(args)
    except subprocess.CalledProcessError as e:
        sys.exit(e.returncode)
    except KeyboardInterrupt:
        sys.exit(130)


if __name__ == "__main__":
    main()
